# Top-level gitignore for both frontend (Node) and backend (Python)

# -----------------
# Node / Frontend
# -----------------
node_modules/
dist/
dist-ssr/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.local

# Vite / bundler outputs
.vite/

# -----------------
# Python / Backend
# -----------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.pytest_cache/
.mypy_cache/
.ruff_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
*.mo
*.pot
.ipynb_checkpoints/
__pypackages__/
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# -----------------
# Editors, OS
# -----------------
.vscode/
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# -----------------
# Project-specific
# -----------------
# Data and models (do not check large datasets or saved models)
backend/data/*.csv
backend/models/saved_model/
backend/models/*.bin
backend/models/*.safetensors
backend/models/*.pt

# Logs
logs
*.log

# Temporary files
*.local

# End of file
